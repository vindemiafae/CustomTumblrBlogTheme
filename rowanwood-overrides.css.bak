
/* =========================================================
   ROWANWOOD ATELIER — ENCHANTED WOODLAND OVERRIDE
   Build notes:
   - Keep Tumblr blocks intact.
   - Edit colors in :root first.
   - Replace image variables in Tumblr Customize panel.
   ========================================================= */

:root {
    --rw-night: #07110b;
    --rw-pine: #102114;
    --rw-deep-moss: #1f3222;
    --rw-moss: #3f613e;
    --rw-fern: #74a66a;
    --rw-sage: #a9c4a0;
    --rw-lily: #ece8d8;
    --rw-moonwater: #8fbfb2;
    --rw-bronze: #b88a67;
    --rw-panel: rgba(14, 28, 17, .88);
    --rw-panel-soft: rgba(28, 49, 32, .78);
    --rw-border: rgba(169, 196, 160, .32);
    --rw-glow: rgba(166, 255, 170, .28);
}

html {
    background: var(--rw-night);
}

body {
    color: var(--rw-lily);
    background:
        radial-gradient(circle at 20% 10%, rgba(116,166,106,.18), transparent 28rem),
        radial-gradient(circle at 80% 30%, rgba(143,191,178,.12), transparent 24rem),
        linear-gradient(rgba(7,17,11,.55), rgba(7,17,11,.9)),
        url('{image:Forest Background}');
    background-color: var(--rw-night);
    background-attachment: fixed;
    background-size: cover;
    background-position: center;
}

/* soft firefly veil */
body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
        radial-gradient(circle at 12% 28%, rgba(190,255,160,.22) 0 2px, transparent 3px),
        radial-gradient(circle at 78% 18%, rgba(143,191,178,.2) 0 2px, transparent 3px),
        radial-gradient(circle at 64% 72%, rgba(236,232,216,.16) 0 2px, transparent 3px),
        radial-gradient(circle at 36% 84%, rgba(180,255,120,.12) 0 2px, transparent 3px);
    animation: rw-fireflies 9s ease-in-out infinite alternate;
}

@keyframes rw-fireflies {
    from { opacity: .35; transform: translateY(0); }
    to { opacity: .8; transform: translateY(-10px); }
}

body > * {
    position: relative;
    z-index: 1;
}

/* Tumblr default theme shell */
.header-wrapper,
.blog-header,
.l-header-container,
.navigation,
.nav-wrapper {
    background: rgba(9, 22, 12, .86) !important;
    border-color: var(--rw-border) !important;
}

.blog-title,
.blog-title a,
.title,
h1, h2, h3,
.widget-title {
    color: var(--rw-lily) !important;
    letter-spacing: .12em;
    text-transform: uppercase;
    text-shadow: 0 0 12px rgba(116,166,106,.3);
}

.description,
.blog-description {
    color: var(--rw-sage) !important;
}

a {
    color: var(--rw-fern);
    transition: color .2s ease, text-shadow .2s ease, border-color .2s ease;
}

a:hover {
    color: var(--rw-lily);
    text-shadow: 0 0 6px var(--rw-glow), 0 0 14px rgba(143,191,178,.22);
}

.post,
.post-wrapper,
.post-content,
.content,
.sidebar,
.widget,
.notes-wrapper,
.related-posts-wrapper {
    background: var(--rw-panel) !important;
    border: 1px solid var(--rw-border) !important;
    box-shadow: 0 18px 45px rgba(0,0,0,.28);
}

.post {
    border-radius: 2px;
}

.post::before {
    content: "✦";
    display: block;
    color: var(--rw-bronze);
    font-size: .85rem;
    letter-spacing: .6em;
    text-align: center;
    margin: .75rem 0 -.25rem;
    opacity: .75;
}

.post-footer,
.post-meta,
.post-date,
.tags,
.caption,
.note-count,
.post_info {
    color: var(--rw-sage) !important;
}

blockquote {
    border-left: 2px solid var(--rw-bronze) !important;
    color: var(--rw-lily);
    background: rgba(169,196,160,.06);
}

button,
.button,
.btn,
input[type="submit"],
.search-field,
input,
textarea {
    background: var(--rw-panel-soft) !important;
    color: var(--rw-lily) !important;
    border: 1px solid var(--rw-border) !important;
}

button:hover,
.button:hover,
.btn:hover {
    border-color: var(--rw-fern) !important;
}

/* Custom woodland welcome card — add markup later once base is stable */
.rw-welcome-card {
    background: var(--rw-panel);
    border: 1px solid var(--rw-border);
    box-shadow: 0 18px 45px rgba(0,0,0,.28);
    padding: 1.25rem;
    text-align: center;
}

.rw-welcome-card::before {
    content: "☾  ✦  🪷  ✦  ☽";
    display: block;
    color: var(--rw-bronze);
    margin-bottom: .75rem;
}

/* readable posts on smaller screens */
@media (max-width: 780px) {
    body {
        background-attachment: scroll;
    }

    .post,
    .post-wrapper,
    .post-content,
    .content,
    .sidebar,
    .widget {
        background: rgba(9, 22, 12, .94) !important;
    }
}

/* ✨ Firefly overlay */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;
  background-image:
    radial-gradient(circle, rgba(190,255,150,.45) 0 1px, transparent 2px),
    radial-gradient(circle, rgba(140,220,180,.25) 0 1px, transparent 3px);
  background-size: 180px 220px, 260px 300px;
  animation: fireflies 18s linear infinite;
  opacity: .45;
}

@keyframes fireflies {
  from { background-position: 0 0, 40px 60px; }
  to { background-position: 180px -220px, -260px -300px; }
}

/* 🪷 Lily / forest dividers */
h2::after,
h3::after,
.post-title::after,
.section-title::after {
  content: "  ✧  ❀  ✧";
  display: block;
  margin-top: .55rem;
  color: #9bcf8d;
  font-size: .75rem;
  letter-spacing: .25rem;
  opacity: .8;
}

/* 🐉 Dragonfly glow hover */
a {
  transition: color .25s ease, text-shadow .25s ease, transform .25s ease;
}

a:hover {
  color: #baf2b1 !important;
  text-shadow:
    0 0 6px rgba(169, 255, 180, .75),
    0 0 14px rgba(111, 180, 151, .65);
}

/* 🌿 Background image layer */
body {
  background:
    linear-gradient(rgba(5, 18, 9, .82), rgba(5, 18, 9, .9)),
    url("YOUR-BACKGROUND-IMAGE-URL-HERE") center top / cover fixed no-repeat;
}

/* 🎵 Music widget */
.forest-music {
  position: fixed;
  right: 18px;
  bottom: 18px;
  z-index: 10000;
  background: rgba(9, 28, 14, .86);
  border: 1px solid rgba(155, 207, 141, .45);
  box-shadow: 0 0 20px rgba(105, 180, 100, .18);
  padding: 10px;
  border-radius: 999px;
  overflow: hidden;
  max-width: 42px;
  height: 42px;
  transition: all .35s ease;
}

.forest-music span {
  color: #baf2b1;
  font-size: 1.1rem;
  display: block;
  text-align: center;
  line-height: 22px;
}

.forest-music iframe {
  display: none;
  margin-top: 8px;
}

.forest-music:hover {
  max-width: 250px;
  height: 112px;
  border-radius: 18px;
}

.forest-music:hover iframe {
  display: block;
}

/* 🌲 Full-page hero background */
body {
  background:
    linear-gradient(
      rgba(3, 16, 9, 0.78),
      rgba(3, 16, 9, 0.92)
    ),
    url("./assets/hero-forest.png") center top / cover fixed no-repeat !important;
}

/* 🪷 Pond banner */
#header,
.header,
.blog-header,
.hero,
.top-banner {
  background:
    linear-gradient(
      rgba(3, 16, 9, 0.25),
      rgba(3, 16, 9, 0.65)
    ),
    url("https://raw.githubusercontent.com/vindemiafae/customtumblrblogtheme/main/assets/image 1.png") center center / cover no-repeat !important;
}

/* ✨ Divider using your asset strip */
.post::before,
.posts article::before,
.entry::before {
  content: "";
  display: block;
  width: 100%;
  height: 42px;
  margin: 0 auto 1.5rem;
  background: url("https://raw.githubusercontent.com/vindemiafae/customtumblrblogtheme/main/assets/image 2.png") center center / contain no-repeat;
  opacity: 0.8;
  pointer-events: none;
}